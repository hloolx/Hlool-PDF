# Hlool PDF environment template for Baota/panel-style binary deployment.
#
# Release packages also include a copy named hlool-pdf.env. The binary
# automatically reads hlool-pdf.env from the current directory or the binary
# directory before it reads OS environment variables.

# Listen on every interface. Open this port in your server firewall/security
# group, then visit http://SERVER_IP:8080 .
HLOOL_ADDR=0.0.0.0:8080

# Store SQLite database, stamps, and settings in the release directory.
HLOOL_DATA_DIR=./data

# Empty means any Host header is accepted. This is convenient for direct IP,
# Baota, and CDN/proxy changes. Set it later if you want to lock to one domain.
HLOOL_ALLOWED_HOSTS=

# Set to 1 only when HTTPS is terminated by a reverse proxy in front.
HLOOL_BEHIND_PROXY=0

# Recommended for public deployments. Admin can re-enable guest mode later.
HLOOL_ALLOW_GUEST=0

# Recommended before configuring OAuth, SMTP, or AI matting providers.
# Generate with: openssl rand -hex 32
# HLOOL_PROVIDER_ENCRYPTION_SECRET=CHANGE_ME_WITH_OPENSSL_RAND_HEX_32

# Optional first-start admin bootstrap. The install wizard works without this.
# HLOOL_ADMIN_USERNAME=admin
# HLOOL_ADMIN_PASSWORD=CHANGE_ME

# Optional limits for smaller servers.
# HLOOL_MAX_PROCESS_BODY_MB=220
# HLOOL_MAX_STAMP_MB=20
# HLOOL_MAX_CONCURRENT_JOBS=2

# Optional S3-compatible stamp/settings storage. Leave unset for local filesystem.
# HLOOL_S3_BUCKET=
# HLOOL_S3_REGION=
# HLOOL_S3_ENDPOINT=
# HLOOL_S3_PREFIX=
# HLOOL_S3_FORCE_PATH_STYLE=0
